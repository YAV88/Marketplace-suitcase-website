# --- Системные файлы ---
.DS_Store          # MacOS мусор
Thumbs.db          # Windows мусор
.env*              # ВАЖНО: Никогда не заливайте .env файлы с ключами Supabase!

# --- Зависимости ---
node_modules/      # Огромная папка, которую сервер GitHub должен качать сам через npm install

# --- Логи и отчеты ---
*.log
*.tmp
*.bak

# --- Сборка и временные файлы ---
dist/
build/
.output/

# --- Локальная среда ---
.vscode/           # Настройки вашего редактора
.idea/             # Настройки WebStorm/PhpStorm

# --- Важные исключения (если вдруг нужны) ---
#!config.js        # Если вы все же хотите хранить config.js, уберите # перед !